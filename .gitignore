# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Environments
venv/
.env
.env.*

# Data — large CSVs, never commit
data/raw/*.csv
data/interim/*.csv
data/processed/*.csv
data/external/*.csv

# Model artifacts — large files, never commit
models/sklearn/random_forest.pkl

# Logs
logs/*

# Visualizations (regenerated by notebook)
reports/figures/*.png

# Keep folder structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!models/.gitkeep
!logs/.gitkeep
!reports/figures/.gitkeep

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
